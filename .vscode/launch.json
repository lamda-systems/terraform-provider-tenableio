{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Terraform Provider",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}",
      "args": ["-debug"],
      "env": {
        "TF_ACC": "1"
      }
    },
    {
      "name": "Debug Acceptance Tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/internal/provider",
      "env": {
        "TF_ACC": "1"
      }
    }
  ]
}
