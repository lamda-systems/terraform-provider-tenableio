{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generate Docs",
      "type": "shell",
      "command": "make docs",
      "group": "build",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "detail": "Generate Terraform Registry documentation from schema and examples",
      "problemMatcher": []
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "make build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "problemMatcher": ["$go"]
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "make lint",
      "group": "test",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "problemMatcher": ["$go"]
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "make test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "problemMatcher": ["$go"]
    },
    {
      "label": "Security: gosec",
      "type": "shell",
      "command": "gosec ./...",
      "group": "test",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "detail": "Static analysis for security vulnerabilities in Go code",
      "problemMatcher": []
    },
    {
      "label": "Security: govulncheck",
      "type": "shell",
      "command": "govulncheck ./...",
      "group": "test",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "detail": "Check Go dependencies for known vulnerabilities",
      "problemMatcher": []
    },
    {
      "label": "Security: All",
      "dependsOn": ["Security: gosec", "Security: govulncheck"],
      "dependsOrder": "parallel",
      "group": "test",
      "detail": "Run all security checks (gosec + govulncheck)",
      "problemMatcher": []
    },
    {
      "label": "Pre-commit Hook",
      "type": "shell",
      "command": "bash ${workspaceFolder}/.githooks/pre-commit",
      "group": "test",
      "detail": "Run the full pre-commit hook (lint + security + tests)",
      "problemMatcher": ["$go"]
    }
  ]
}
